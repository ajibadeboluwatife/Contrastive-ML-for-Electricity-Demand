baseline_accuracy = accuracy_score(targets_test, targets_pred)class WindowedTimeSeriesDataset(torch.utils.data.Dataset):
    def __init__(self, data, features, window_size):
        self.data = data[features].values.astype(np.float32)
        self.window_size = window_size

    def __len__(self):
        return len(self.data) - self.window_size

    def __getitem__(self, idx):
        window = self.data[idx:idx + self.window_size]
        anchor = torch.tensor(window)
        pos = anchor + 0.01 * torch.randn_like(anchor)
        neg_idx = (idx + torch.randint(1, 500, ()).item()) % (len(self.data) - self.window_size)
        neg = torch.tensor(self.data[neg_idx:neg_idx + self.window_size])
        return anchor, pos, neg
WINDOW_SIZE = 48
features = ['nswprice', 'nswdemand', 'vicprice', 'vicdemand', 'transfer']
contrastive_dataset = WindowedTimeSeriesDataset(electricity_demands, features, WINDOW_SIZE)
contrastive_loader = torch.utils.data.DataLoader(contrastive_dataset, batch_size = 128, shuffle = True)class Encoder(nn.Module):
    def __init__(self, input_dim=5, latent_dim=32):
        super().__init__()
        self.net = nn.Sequential(
            nn.Conv1d(input_dim, 32, 3, padding=1),
            nn.ReLU(),
            nn.Conv1d(32, 64, 3, padding=1),
            nn.ReLU(),
            nn.AdaptiveAvgPool1d(1),
        )
        self.fc = nn.Linear(64, latent_dim)

    def forward(self, x):
        x = x.permute(0, 2, 1)
        x = self.net(x).squeeze(-1)
        return self.fc(x)
device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
encoder = Encoder().to(device)
opt = torch.optim.Adam(encoder.parameters(), lr=1e-3)

def contrastive_loss(a, p, n, margin=1.0):
    return torch.mean(F.relu(F.pairwise_distance(a, p) - F.pairwise_distance(a, n) + margin))

encoder.train()
for epoch in range(10):
    total = 0
    for a, p, n in contrastive_loader:
        a, p, n = a.to(device), p.to(device), n.to(device)
        za, zp, zn = encoder(a), encoder(p), encoder(n)
        loss = contrastive_loss(za, zp, zn)
        opt.zero_grad()
        loss.backward()
        opt.step()
        total += loss.item()
    print(f"Epoch {epoch+1}: Loss {total:.4f}")@torch.no_grad()
def generate_embeddings(encoder, data, features, window_size, batch_size = 1024):
    encoder.eval()
    all_embeddings = []
    for i in range(0, len(data) - window_size, batch_size):
        batch = []
        for j in range(i, min(i + batch_size, len(data) - window_size)):
            window = data[features].iloc[j:j + window_size].values.astype(np.float32)
            batch.append(window)
        batch_tensor = torch.tensor(batch).to(device)
        embedding = encoder(batch_tensor).cpu()
        all_embeddings.append(embedding)
    return torch.cat(all_embeddings, dim=0)

Z = generate_embeddings(encoder, electricity_demands, features, WINDOW_SIZE)
Z_full = np.zeros((len(electricity_demands), Z.shape[1]))
Z_full[WINDOW_SIZE:] = Z

for i in range(Z.shape[1]):
