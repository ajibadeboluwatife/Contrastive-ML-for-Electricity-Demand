class ElectricityDemandClassifier:
    def __init__(self, data, target_column, sample_fraction = 0.5, test_size = 0.2, random_state = 42):
        self.data = data
        self.target_column = target_column
        self.sample_fraction = sample_fraction
        self.test_size = test_size
        self.random_state = random_state
        
        sampled_data = self.data.groupby(self.target_column, group_keys = False).apply(
            lambda x: x.sample(frac = self.sample_fraction, random_state = self.random_state)
        )

        self.features = sampled_data.drop(self.target_column, axis = 1)
        self.targets = sampled_data[self.target_column]

        self.features_train, self.features_test, self.targets_train, self.targets_test = train_test_split(
            self.features,
            self.targets,
            test_size = self.test_size,
            random_state = self.random_state,
            stratify = self.targets
        )

        self.lazyClassifier = LazyClassifier(verbose = 0, ignore_warnings = True, custom_metric = None)
        self.models = None
        self.predictions = None

    def fit(self):
        self.models, self.predictions = self.lazyClassifier.fit(
            self.features_train, 
            self.features_test, 
            self.targets_train, 
            self.targets_test)

    def get_models(self):
        return self.models

    def get_predictions(self):
        return self.predictions
